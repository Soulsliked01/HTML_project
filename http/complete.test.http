###
# ============================================================
# Games Manager — Full HTTP Test Battery
# Ordre d'exécution : lancer dans l'ordre, les logins nommés
# sont réutilisés via {{xxx_login.response.body.token}}
# ============================================================

@server = http://127.0.0.1:3000
@adminuser = admin
@adminpassword = admin
@playeruser = player
@playerpassword = player
@refuser = ref
@refpassword = ref
@traineruser = trainer
@trainerpassword = trainer


# ============================================================
# AUTH
# ============================================================

###
# [OK 200] Login admin
# @name admin_login
POST {{server}}/auth/login HTTP/1.1
Content-Type: application/json

{
  "username": "{{adminuser}}",
  "password": "{{adminpassword}}"
}

###
# [OK 200] Login player
# @name player_login
POST {{server}}/auth/login HTTP/1.1
Content-Type: application/json

{
  "username": "{{playeruser}}",
  "password": "{{playerpassword}}"
}

###
# [OK 200] Login referee
# @name ref_login
POST {{server}}/auth/login HTTP/1.1
Content-Type: application/json

{
  "username": "{{refuser}}",
  "password": "{{refpassword}}"
}

###
# [OK 200] Login trainer
# @name trainer_login
POST {{server}}/auth/login HTTP/1.1
Content-Type: application/json

{
  "username": "{{traineruser}}",
  "password": "{{trainerpassword}}"
}

###
# [FAIL 400] Login — missing password
POST {{server}}/auth/login HTTP/1.1
Content-Type: application/json

{
  "username": "admin"
}

###
# [FAIL 400] Login — empty username
POST {{server}}/auth/login HTTP/1.1
Content-Type: application/json

{
  "username": "",
  "password": "admin"
}

###
# [FAIL 401] Login — wrong password
POST {{server}}/auth/login HTTP/1.1
Content-Type: application/json

{
  "username": "admin",
  "password": "wrongpassword"
}

###
# [FAIL 401] Login — unknown user
POST {{server}}/auth/login HTTP/1.1
Content-Type: application/json

{
  "username": "ghost",
  "password": "whatever"
}


# ============================================================
# USERS — CREATE (public)
# ============================================================

###
# [OK 201] Create user jane
POST {{server}}/users HTTP/1.1
Content-Type: application/json

{
  "email": "jane@example.com",
  "password": "1234",
  "firstName": "Jane",
  "lastName": "Doe",
  "username": "jane"
}

###
# [FAIL 400] Email sans @
POST {{server}}/users HTTP/1.1
Content-Type: application/json

{
  "email": "janeexample.com",
  "password": "superstrongpassword",
  "firstName": "Jane",
  "lastName": "Doe",
  "username": "failing1"
}

###
# [FAIL 400] Email sans .
POST {{server}}/users HTTP/1.1
Content-Type: application/json

{
  "email": "jane@examplecom",
  "password": "superstrongpassword",
  "firstName": "Jane",
  "lastName": "Doe",
  "username": "failing2"
}

###
# [FAIL 400] DTO incomplet — pas de password
POST {{server}}/users HTTP/1.1
Content-Type: application/json

{
  "email": "jane@example.com",
  "firstName": "Jane",
  "username": "failing3"
}

###
# [FAIL 400] Username déjà pris
POST {{server}}/users HTTP/1.1
Content-Type: application/json

{
  "email": "jane2@example.com",
  "password": "1234",
  "firstName": "Jane",
  "lastName": "Doe",
  "username": "jane"
}

###
# [FAIL 400] Email déjà pris
POST {{server}}/users HTTP/1.1
Content-Type: application/json

{
  "email": "jane@example.com",
  "password": "1234",
  "firstName": "Jane",
  "lastName": "Doe",
  "username": "jane_other"
}

###
# [OK 200] Login jane
# @name jane_login
POST {{server}}/auth/login HTTP/1.1
Content-Type: application/json

{
  "username": "jane",
  "password": "1234"
}


# ============================================================
# USERS — READ
# ============================================================

###
# [FAIL 401] GET /users — sans token
GET {{server}}/users HTTP/1.1

###
# [OK 200] GET /users — admin reçoit UserDTO[]
GET {{server}}/users HTTP/1.1
Authorization: {{admin_login.response.body.token}}

###
# [OK 200] GET /users — player reçoit UserShortDTO[]
GET {{server}}/users HTTP/1.1
Authorization: {{player_login.response.body.token}}

###
# [FAIL 401] GET /users/:id — sans token
GET {{server}}/users/1 HTTP/1.1

###
# [OK 200] GET /users/:id — admin voit UserDTO complet
GET {{server}}/users/1 HTTP/1.1
Authorization: {{admin_login.response.body.token}}

###
# [OK 200] GET /users/:id — user voit son propre profil (UserDTO)
GET {{server}}/users/2 HTTP/1.1
Authorization: {{player_login.response.body.token}}

###
# [OK 200] GET /users/:id — user voit un autre profil (UserShortDTO)
GET {{server}}/users/1 HTTP/1.1
Authorization: {{player_login.response.body.token}}

###
# [FAIL 404] GET /users/:id — user inexistant
GET {{server}}/users/99999 HTTP/1.1
Authorization: {{admin_login.response.body.token}}

###
# [FAIL 401] GET /users/username/:username — sans token
GET {{server}}/users/username/admin HTTP/1.1

###
# [OK 200] GET /users/username/:username — admin
GET {{server}}/users/username/admin HTTP/1.1
Authorization: {{admin_login.response.body.token}}

###
# [OK 200] GET /users/username/:username — referee
GET {{server}}/users/username/admin HTTP/1.1
Authorization: {{ref_login.response.body.token}}

###
# [FAIL 403] GET /users/username/:username — player interdit
GET {{server}}/users/username/admin HTTP/1.1
Authorization: {{player_login.response.body.token}}

###
# [FAIL 403] GET /users/username/:username — trainer interdit
GET {{server}}/users/username/admin HTTP/1.1
Authorization: {{trainer_login.response.body.token}}

###
# [FAIL 404] GET /users/username/:username — username inexistant
GET {{server}}/users/username/ghostuser HTTP/1.1
Authorization: {{admin_login.response.body.token}}

###
# [FAIL 401] GET /users/email/:email — sans token
GET {{server}}/users/email/admin@vinci.be HTTP/1.1

###
# [OK 200] GET /users/email/:email — admin
GET {{server}}/users/email/admin@vinci.be HTTP/1.1
Authorization: {{admin_login.response.body.token}}

###
# [OK 200] GET /users/email/:email — referee
GET {{server}}/users/email/admin@vinci.be HTTP/1.1
Authorization: {{ref_login.response.body.token}}

###
# [FAIL 403] GET /users/email/:email — player interdit
GET {{server}}/users/email/admin@vinci.be HTTP/1.1
Authorization: {{player_login.response.body.token}}

###
# [FAIL 404] GET /users/email/:email — email inexistant
GET {{server}}/users/email/nobody@nowhere.com HTTP/1.1
Authorization: {{admin_login.response.body.token}}


# ============================================================
# USERS — UPDATE
# ============================================================

###
# [FAIL 401] PUT /users/:id — sans token
PUT {{server}}/users/2 HTTP/1.1
Content-Type: application/json

{
  "id": 2,
  "email": "modified@vinci.be",
  "firstName": "Modified",
  "lastName": "User",
  "username": "newplayer",
  "role": "player",
  "status": "active"
}

###
# [FAIL 400] PUT /users/:id — body.id != path.id
PUT {{server}}/users/1 HTTP/1.1
Authorization: {{player_login.response.body.token}}
Content-Type: application/json

{
  "id": 2,
  "email": "modified@vinci.be",
  "firstName": "Modified",
  "lastName": "User",
  "username": "newplayer",
  "role": "player",
  "status": "active"
}

###
# [FAIL 403] PUT /users/:id — player modifie un autre user
PUT {{server}}/users/1 HTTP/1.1
Authorization: {{player_login.response.body.token}}
Content-Type: application/json

{
  "id": 1,
  "email": "hacked@vinci.be",
  "firstName": "Hacked",
  "lastName": "Admin",
  "username": "hacked",
  "role": "admin",
  "status": "active"
}

###
# [OK 200] PUT /users/:id — player modifie son propre profil
# role et status ignorés server-side
PUT {{server}}/users/2 HTTP/1.1
Authorization: {{player_login.response.body.token}}
Content-Type: application/json

{
  "id": 2,
  "email": "player@vinci.be",
  "firstName": "Player",
  "lastName": "Updated",
  "username": "player",
  "role": "admin",
  "status": "inactive"
}

###
# [FAIL 404] PUT /users/:id — user inexistant
PUT {{server}}/users/99999 HTTP/1.1
Authorization: {{admin_login.response.body.token}}
Content-Type: application/json

{
  "id": 99999,
  "email": "ghost@vinci.be",
  "firstName": "Ghost",
  "lastName": "User",
  "username": "ghost",
  "role": "player",
  "status": "active"
}

###
# [OK 200] PUT /users/:id — admin modifie n'importe quel user
PUT {{server}}/users/2 HTTP/1.1
Authorization: {{admin_login.response.body.token}}
Content-Type: application/json

{
  "id": 2,
  "email": "player@vinci.be",
  "firstName": "player",
  "lastName": "player",
  "username": "player",
  "role": "player",
  "status": "active"
}


# ============================================================
# USERS — ROLE
# ============================================================

###
# [FAIL 401] PATCH /users/:id/role/:role — sans token
PATCH {{server}}/users/2/role/referee HTTP/1.1

###
# [FAIL 403] PATCH /users/:id/role/:role — player interdit
PATCH {{server}}/users/2/role/trainer HTTP/1.1
Authorization: {{player_login.response.body.token}}

###
# [FAIL 400] PATCH /users/:id/role/:role — role invalide
PATCH {{server}}/users/2/role/superadmin HTTP/1.1
Authorization: {{admin_login.response.body.token}}

###
# [FAIL 400] PATCH /users/:id/role/:role — target n'est pas player (ref=id3)
PATCH {{server}}/users/3/role/admin HTTP/1.1
Authorization: {{admin_login.response.body.token}}

###
# [FAIL 404] PATCH /users/:id/role/:role — user inexistant
PATCH {{server}}/users/99999/role/referee HTTP/1.1
Authorization: {{admin_login.response.body.token}}

###
# [OK 200] PATCH /users/:id/role/:role — admin change le role de jane (player → referee)
PATCH {{server}}/users/5/role/referee HTTP/1.1
Authorization: {{admin_login.response.body.token}}


# ============================================================
# USERS — DELETE (soft)
# ============================================================

###
# [FAIL 401] DELETE /users/:id — sans token
DELETE {{server}}/users/5 HTTP/1.1

###
# [FAIL 403] DELETE /users/:id — player supprime un autre
DELETE {{server}}/users/5 HTTP/1.1
Authorization: {{player_login.response.body.token}}

###
# [FAIL 400] DELETE /users/:id — tentative de supprimer admin
DELETE {{server}}/users/1 HTTP/1.1
Authorization: {{admin_login.response.body.token}}

###
# [FAIL 404] DELETE /users/:id — user inexistant
DELETE {{server}}/users/99999 HTTP/1.1
Authorization: {{admin_login.response.body.token}}

###
# [OK 200] DELETE /users/:id — admin supprime jane (soft-delete)
DELETE {{server}}/users/5 HTTP/1.1
Authorization: {{admin_login.response.body.token}}


