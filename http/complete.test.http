Authorization: {{ref_login.response.body.token}}

###
# [FAIL 400] PATCH /games/:id/status/started — game pas scheduled (game 1 = created)
PATCH {{server}}/games/1/status/started HTTP/1.1
Authorization: {{ref_login.response.body.token}}

###
# [OK 200] PATCH /games/:id/status/cancelled — created → cancelled
PATCH {{server}}/games/1/status/cancelled HTTP/1.1
Authorization: {{ref_login.response.body.token}}

###
# [FAIL 400] PATCH /games/:id/status — transition invalide (cancelled → started)
PATCH {{server}}/games/1/status/started HTTP/1.1
Authorization: {{ref_login.response.body.token}}

###
# [OK 200] PATCH /games/:id/status/started — scheduled → started (game 2)
PATCH {{server}}/games/2/status/started HTTP/1.1
Authorization: {{ref_login.response.body.token}}

###
# [FAIL 403] PATCH /games/:id/score — player interdit
PATCH {{server}}/games/2/score/2/1 HTTP/1.1
Authorization: {{player_login.response.body.token}}

###
# [OK 200] PATCH /games/:id/score — referee set le score
PATCH {{server}}/games/2/score/3/1 HTTP/1.1
Authorization: {{ref_login.response.body.token}}

###
# [FAIL 400] PATCH /games/:id/score — game pas started (game 1 = cancelled)
PATCH {{server}}/games/1/score/1/0 HTTP/1.1
Authorization: {{ref_login.response.body.token}}

###
# [OK 200] PATCH /games/:id/status/finished — started → finished
PATCH {{server}}/games/2/status/finished HTTP/1.1
Authorization: {{ref_login.response.body.token}}

###
# [FAIL 400] PATCH /games/:id/status — finished → cancelled (interdit)
PATCH {{server}}/games/2/status/cancelled HTTP/1.1
Authorization: {{ref_login.response.body.token}}

###
# [FAIL 400] PUT /games/:id — game finished ne peut pas être modifiée
PUT {{server}}/games/2 HTTP/1.1
Content-Type: application/json
Authorization: {{ref_login.response.body.token}}

{
  "id": 2,
  "name": "Cannot update finished game"
}

###
# [FAIL 403] DELETE /games/:id — referee interdit
DELETE {{server}}/games/2 HTTP/1.1
Authorization: {{ref_login.response.body.token}}

###
# [FAIL 401] DELETE /games/:id — sans token
DELETE {{server}}/games/2 HTTP/1.1

###
# [OK 204] DELETE /games/:id — admin hard delete
DELETE {{server}}/games/2 HTTP/1.1
Authorization: {{admin_login.response.body.token}}